<Window x:Class="TakojsnjeSporocanje.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nastavitve"
        Width="700"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF4F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF1E293B"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,12"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#FFD5DCEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FF0F172A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FF334155"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#FFE8EEF9"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FF2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="28"
                Padding="22"
                BorderBrush="#FFE2E8F0"
                BorderThickness="1">
            <TabControl>
                <TabItem Header="Osebni podatki">
                    <Border Background="#FFF8FAFC"
                            CornerRadius="20"
                            Padding="20"
                            Margin="0,16,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="0,0,6,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <Grid Width="160" Height="160" HorizontalAlignment="Center">
                                        <Ellipse Fill="#FFEFF4FB"
                                                 Stroke="#FFD5DCEA"
                                                 StrokeThickness="1"/>
                                        <Ellipse Margin="4">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding EditableProfile.ImagePath}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>

                                    <Button Content="{Binding ImageButtonText}"
                                            Margin="0,18,0,0"
                                            Background="#FFE8EEF9"
                                            Foreground="#FF1D4ED8"
                                            Click="LoadImage_Click"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Vzdevek" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditableProfile.Nickname, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Priimek" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditableProfile.LastName, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Email" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditableProfile.Email, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Telefonska &#353;tevilka" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditableProfile.Phone, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Kraj" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditableProfile.City, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Dr&#382;ava" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditableProfile.Country, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Opis" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditableProfile.About, UpdateSourceTrigger=PropertyChanged}"
                                             Height="110"
                                             Padding="12,10"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"/>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <TabItem Header="Samodejno shranjevanje">
                    <Border Background="#FFF8FAFC"
                            CornerRadius="20"
                            Padding="24"
                            Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Samodejno shranjevanje"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <CheckBox Content="Omogo&#269;i samodejno shranjevanje"
                                      Margin="0,20,0,14"
                                      FontSize="15"/>
                            <TextBlock Text="&#268;asovni interval v minutah"
                                       FontWeight="SemiBold"/>
                            <TextBox Width="140"
                                     Text="5"/>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Prekli&#269;i"
                    Background="#FFE5E7EB"
                    Foreground="#FF0F172A"
                    Click="Cancel_Click"/>
            <Button Content="Shrani"
                    Background="#FF2563EB"
                    Foreground="White"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
