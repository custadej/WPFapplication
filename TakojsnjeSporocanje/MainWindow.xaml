<Window x:Class="TakojsnjeSporocanje.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Takoj&#353;nje sporo&#269;anje"
        Height="720"
        Width="1220"
        MinHeight="640"
        MinWidth="1000"
        Background="#FFF1F5FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#FF0F172A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="TopMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FF1E293B"/>
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter Property="Background" Value="#FF1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="Foreground" Value="#FF0F172A"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FFEAF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuIconTextStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="LineHeight" Value="20"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FF0F172A"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,12"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="BorderBrush" Value="#FFD6DCE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0,8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FF0F172A"/>
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="BorderBrush" Value="#FFD6DCE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="17"
                                    ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="12,0,0,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"/>
                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="0">
                                        <Path Width="10"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 5 6 L 10 0"
                                              Stroke="#2455D6"
                                              StrokeThickness="2"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,8,0,0"
                                        MinWidth="{Binding ActualWidth, ElementName=ComboBorder}"
                                        Background="White"
                                        BorderBrush="#D6DCE7"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#2F6BFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF2F6BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFEAF1FF"/>
            <Setter Property="Foreground" Value="#FF2455D6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datoteka" Style="{StaticResource TopMenuItemStyle}">
                <MenuItem Header="Izhod" Style="{StaticResource SubMenuItemStyle}" Click="MenuExit_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#x21AA;"
                                   Style="{StaticResource MenuIconTextStyle}"
                                   Foreground="#FFDC2626"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="Stiki" Style="{StaticResource TopMenuItemStyle}">
                <MenuItem Header="Dodaj..." Style="{StaticResource SubMenuItemStyle}" Click="MenuAddContact_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="+"
                                   Style="{StaticResource MenuIconTextStyle}"
                                   FontWeight="Bold"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="RemoveContactMenuItem" Header="Odstrani" Style="{StaticResource SubMenuItemStyle}" Click="MenuRemoveContact_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="-"
                                   Style="{StaticResource MenuIconTextStyle}"
                                   FontWeight="Bold"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="EditContactMenuItem" Header="Uredi..." Style="{StaticResource SubMenuItemStyle}" Click="MenuEditContact_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#x270E;"
                                   Style="{StaticResource MenuIconTextStyle}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="Orodja" Style="{StaticResource TopMenuItemStyle}">
                <MenuItem Header="Nastavitve" Style="{StaticResource SubMenuItemStyle}" Click="MenuSettings_Click">
                    <MenuItem.Icon>
                        <Viewbox Width="16"
                                 Height="16"
                                 Stretch="Uniform">
                            <Canvas Width="16" Height="16">
                                <Path Width="16"
                                      Height="16"
                                      Fill="#FF0F172A"
                                      Data="M8,1.8 L9.1,1.8 L9.5,3.1 C10,3.3 10.5,3.5 10.9,3.8 L12.2,3.3 L13,4.1 L12.5,5.4 C12.8,5.8 13,6.3 13.2,6.8 L14.5,7.2 L14.5,8.3 L13.2,8.7 C13,9.2 12.8,9.7 12.5,10.1 L13,11.4 L12.2,12.2 L10.9,11.7 C10.5,12 10,12.2 9.5,12.4 L9.1,13.7 L8,13.7 L7.6,12.4 C7.1,12.2 6.6,12 6.2,11.7 L4.9,12.2 L4.1,11.4 L4.6,10.1 C4.3,9.7 4.1,9.2 3.9,8.7 L2.6,8.3 L2.6,7.2 L3.9,6.8 C4.1,6.3 4.3,5.8 4.6,5.4 L4.1,4.1 L4.9,3.3 L6.2,3.8 C6.6,3.5 7.1,3.3 7.6,3.1 Z M8.55,5.1 C9.88,5.1 10.95,6.17 10.95,7.5 C10.95,8.83 9.88,9.9 8.55,9.9 C7.22,9.9 6.15,8.83 6.15,7.5 C6.15,6.17 7.22,5.1 8.55,5.1 Z"/>
                            </Canvas>
                        </Viewbox>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FF121A2C"
                    CornerRadius="28"
                    Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#FF202A3E"
                            CornerRadius="22"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="64" Height="64">
                                <Ellipse Fill="#FF0B1120"
                                         Stroke="#FF334155"
                                         StrokeThickness="1"/>
                                <Ellipse Margin="3">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding AppData.CurrentUser.ImagePath}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,10">
                                    <TextBlock Text="{Binding AppData.CurrentUser.Nickname}"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <Ellipse Width="10"
                                             Height="10"
                                             Margin="8,14,0,0"
                                             VerticalAlignment="Top">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#94A3B8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AppData.CurrentUser.Status}" Value="Online">
                                                        <Setter Property="Fill" Value="#4ADE80"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AppData.CurrentUser.Status}" Value="Away">
                                                        <Setter Property="Fill" Value="#FBBF24"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AppData.CurrentUser.Status}" Value="Busy">
                                                        <Setter Property="Fill" Value="#F87171"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </StackPanel>
                                <ComboBox Name="CurrentUserStatusComboBox"
                                          Style="{StaticResource RoundedComboBoxStyle}"
                                          Height="34"
                                          MinWidth="150"
                                          PreviewMouseWheel="ComboBox_PreviewMouseWheel"
                                          SelectedItem="{Binding AppData.CurrentUser.Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <sys:String>Online</sys:String>
                                    <sys:String>Away</sys:String>
                                    <sys:String>Busy</sys:String>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="4,10,4,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Stiki"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>

                            <Border Grid.Column="1"
                                    Background="#223A5F"
                                    CornerRadius="14"
                                    Padding="12,5"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding ContactCountText}"
                                           Foreground="#BFDBFE"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>

                    <ListView Grid.Row="2"
                              ItemsSource="{Binding AppData.Contacts}"
                              SelectedItem="{Binding SelectedContact, Mode=TwoWay}"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14"
                                        CornerRadius="20"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FF202A3E"/>
                                            <Setter Property="BorderBrush" Value="#FF334155"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                                    <Setter Property="Background" Value="#FF263550"/>
                                                    <Setter Property="BorderBrush" Value="#FF55657F"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#FF3053A5"/>
                                                    <Setter Property="BorderBrush" Value="#FFA6C8FF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="48" Height="48">
                                            <Ellipse Fill="#FF0B1120"/>
                                            <Ellipse Margin="2">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding ImagePath}" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Nickname}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           FontSize="17"/>
                                                <Ellipse Width="10"
                                                         Height="10"
                                                         Margin="8,8,0,0"
                                                         VerticalAlignment="Top">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#94A3B8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Online">
                                                                    <Setter Property="Fill" Value="#4ADE80"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Away">
                                                                    <Setter Property="Fill" Value="#FBBF24"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Busy">
                                                                    <Setter Property="Fill" Value="#F87171"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Email}"
                                                       Foreground="#FFCBD5E1"
                                                       FontSize="12"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#FFF7FAFF"
                        CornerRadius="28"
                        Padding="18"
                        BorderBrush="#FFD8E4F6"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Width="72" Height="72" VerticalAlignment="Center">
                            <Ellipse Fill="#FFDCEBFF"/>
                            <Ellipse Margin="4">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding SelectedContact.ImagePath}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Margin="18,0,0,0"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Path=SelectedContact.Nickname, TargetNullValue=Izberi stik}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="#FF0F172A"/>
                                <Ellipse Width="11"
                                         Height="11"
                                         Margin="10,14,0,0"
                                         VerticalAlignment="Top">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#94A3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedContact.Status}" Value="Online">
                                                    <Setter Property="Fill" Value="#4ADE80"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedContact.Status}" Value="Away">
                                                    <Setter Property="Fill" Value="#FBBF24"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedContact.Status}" Value="Busy">
                                                    <Setter Property="Fill" Value="#F87171"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </StackPanel>
                            <TextBlock Text="{Binding Path=SelectedContact.Email, StringFormat=Email: {0}, TargetNullValue=Email: }"
                                       Margin="0,5,0,0"
                                       FontSize="14"
                                       Foreground="#FF475569"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="Nazadnje aktiven"
                                       HorizontalAlignment="Right"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#FF7C8EAD"/>
                            <Border Margin="0,6,0,0"
                                    Background="#FFF4F8FF"
                                    BorderBrush="#FFD7E6FF"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="12,7">
                                <TextBlock Text="{Binding Path=SelectedContact.LastActive, TargetNullValue=-}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#FF1D4ED8"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           MinWidth="54"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,18"
                        Background="White"
                        CornerRadius="28"
                        Padding="22"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1">
                    <ScrollViewer Name="ChatScrollViewer"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CurrentConversationMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MaxWidth="340"
                                            Margin="0,0,0,12"
                                            Padding="16,12"
                                            CornerRadius="20">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FF94A3B8"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                                                        <Setter Property="Background" Value="#FF3053A5"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Text}"
                                                   TextWrapping="Wrap"
                                                   FontSize="15"
                                                   LineHeight="24">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="28"
                        Padding="18"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="132"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Name="MessageTextBox"
                                 Grid.Column="0"
                                 Height="44"
                                 Background="#FFF8FAFC"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,12,0"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,12,0"
                                Click="EmojiButton_Click">
                            <Image Source="Images/smile.png" Width="18" Height="18"/>
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="44"
                                Click="SendButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="Images/send.png"
                                       Width="16"
                                       Height="16"
                                       Margin="0,0,6,0"/>
                                <TextBlock Text="Po&#353;lji"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
