<Window x:Class="TakojsnjeSporocanje.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Takojšnje sporočanje"
        Height="650"
        Width="1100"
        FontFamily="Segoe UI">

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datoteka">
                <MenuItem Header="Izhod" Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="Stiki">
                <MenuItem Header="Dodaj" Click="MenuAddContact_Click"/>
                <MenuItem Header="Odstrani" Click="MenuRemoveContact_Click"/>
                <MenuItem Header="Uredi" Click="MenuEditContact_Click"/>
            </MenuItem>

            <MenuItem Header="Orodja">
                <MenuItem Header="Nastavitve" Click="MenuSettings_Click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEVA STRAN -->
            <Border Grid.Column="0"
                    Background="#f0f2f5"
                    Padding="15"
                    BorderBrush="#dcdcdc"
                    BorderThickness="0,0,1,0">

                <StackPanel>

                    <TextBlock Text="Vzdevek" FontWeight="Bold"/>
                    <TextBox Name="NicknameTextBox"
                             Text="Tadej"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Status" FontWeight="Bold"/>
                    <ComboBox Height="28" Margin="0,5,0,15">
                        <ComboBoxItem Content="Online"/>
                        <ComboBoxItem Content="Away"/>
                        <ComboBoxItem Content="Busy"/>
                    </ComboBox>

                    <TextBlock Text="Stiki"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>

                    <ListView ItemsSource="{Binding Contacts}"
                              SelectedItem="{Binding SelectedContact, Mode=TwoWay}">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding ImagePath}"
                                           Width="30"
                                           Height="30"
                                           Margin="0,0,10,0"/>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Nickname}"
                                                   FontWeight="Bold"/>

                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Online">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Away">
                                                            <Setter Property="Foreground" Value="Orange"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Busy">
                                                            <Setter Property="Foreground" Value="Red"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                </StackPanel>
            </Border>

            <!-- DESNA STRAN -->
            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding SelectedContact.Nickname, StringFormat=Pogovor z: {0}}"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <Border Grid.Row="1"
                        BorderBrush="#dcdcdc"
                        BorderThickness="1"
                        Padding="15">

                    <ScrollViewer Name="ChatScrollViewer"
                                  VerticalScrollBarVisibility="Auto">

                        <TextBlock Text="{Binding SelectedContact.Conversation}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="22"/>

                    </ScrollViewer>

                </Border>

                <Grid Grid.Row="2" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Name="MessageTextBox"
                             Grid.Column="0"
                             Height="35"/>

                    <Button Grid.Column="1"
                            Click="EmojiButton_Click">
                        <Image Source="Images/smile.png"
                               Width="18"
                               Height="18"/>
                    </Button>

                    <Button Grid.Column="2"
                            Click="SendButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="Images/send.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,5,0"/>
                            <TextBlock Text="Pošlji"/>
                        </StackPanel>
                    </Button>

                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</Window>