<Window x:Class="TakojsnjeSporocanje.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Takojšnje sporočanje"
        Height="650"
        Width="1100"
        FontFamily="Segoe UI">

    <DockPanel>

        <!-- ================= MENU ================= -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datoteka">
                <MenuItem Header="Izhod"
                          Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="Stiki">
                <MenuItem Header="Dodaj"
                          Click="MenuAddContact_Click"/>
                <MenuItem Header="Odstrani"
                          Click="MenuRemoveContact_Click"/>
                <MenuItem Header="Uredi"
                          Click="MenuEditContact_Click"/>
            </MenuItem>

            <MenuItem Header="Orodja">
                <MenuItem Header="Nastavitve"
                          Click="MenuSettings_Click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEVI PANEL -->
            <Border Grid.Column="0"
                    Background="#f0f2f5"
                    Padding="15"
                    BorderBrush="#dcdcdc"
                    BorderThickness="0,0,1,0">

                <StackPanel>

                    <TextBlock Text="Vzdevek"
                               FontWeight="Bold"/>
                    <TextBox Name="NicknameTextBox"
                             Text="Tadej"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Status"
                               FontWeight="Bold"/>
                    <ComboBox Height="28"
                              Margin="0,5,0,15">
                        <ComboBoxItem Content="Online"/>
                        <ComboBoxItem Content="Away"/>
                        <ComboBoxItem Content="Busy"/>
                    </ComboBox>

                    <TextBlock Text="Stiki"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>

                    <ListBox Name="ContactsListBox"
                             Height="350"
                             SelectionChanged="ContactsListBox_SelectionChanged">
                        <ListBoxItem Content="Miha"/>
                        <ListBoxItem Content="Nina"/>
                        <ListBoxItem Content="Daris"/>
                        <ListBoxItem Content="Eva"/>
                    </ListBox>

                </StackPanel>
            </Border>

            <!-- DESNI PANEL -->
            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Name="ChatTitleTextBlock"
                           Text="Pogovor z: Miha"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <Border Grid.Row="1"
                        BorderBrush="#dcdcdc"
                        BorderThickness="1"
                        Padding="15">

                    <ScrollViewer Name="ChatScrollViewer"
                                  VerticalScrollBarVisibility="Auto">

                        <TextBlock Name="ChatContentTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="22"/>

                    </ScrollViewer>

                </Border>

                <Grid Grid.Row="2" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Name="MessageTextBox"
                             Grid.Column="0"
                             Height="35"
                             VerticalContentAlignment="Center"/>

                    <Button Grid.Column="1"
                            Click="EmojiButton_Click">
                        <Image Source="Images/smile.png"
                               Width="18"
                               Height="18"/>
                    </Button>

                    <Button Grid.Column="2"
                            Click="SendButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="Images/send.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,5,0"/>
                            <TextBlock Text="Pošlji"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</Window>