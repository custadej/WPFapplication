<Window x:Class="TakojsnjeSporocanje.ImageCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obrezi sliko"
        Width="980"
        Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#FFF4F7FB"
        FontFamily="Segoe UI">

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Background="White"
                CornerRadius="24"
                BorderBrush="#FFE2E8F0"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Obreži profilno sliko"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#FF0F172A"/>
                    <TextBlock Text="Premakni krog in spodaj prilagodi velikost, da lepo zajame obraz."
                               Margin="0,6,0,0"
                               Foreground="#FF475569"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,18,0,18"
                        Background="#FFF3F7FD"
                        CornerRadius="20"
                        Padding="14">
                    <Grid x:Name="ImageViewport"
                          SizeChanged="ImageViewport_SizeChanged"
                          ClipToBounds="True">
                        <Image x:Name="SourceImage"
                               Stretch="Uniform"/>
                        <Canvas x:Name="OverlayCanvas"
                                Background="Transparent">
                            <Ellipse x:Name="SelectionEllipse"
                                     Stroke="#FF2563EB"
                                     StrokeThickness="4"
                                     Fill="#222563EB"
                                     Cursor="SizeAll"
                                     MouseLeftButtonDown="SelectionEllipse_MouseLeftButtonDown"
                                     MouseMove="SelectionEllipse_MouseMove"
                                     MouseLeftButtonUp="SelectionEllipse_MouseLeftButtonUp"/>
                        </Canvas>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Velikost kroga"
                               FontWeight="SemiBold"
                               Foreground="#FF0F172A"/>
                    <Slider x:Name="SizeSlider"
                            Margin="0,10,0,0"
                            Minimum="80"
                            Maximum="420"
                            ValueChanged="SizeSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="White"
                CornerRadius="24"
                BorderBrush="#FFE2E8F0"
                BorderThickness="1"
                Padding="20">
            <StackPanel>
                <TextBlock Text="Predogled avatarja"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FF0F172A"/>
                <TextBlock Text="Tako bo slika videti v aplikaciji."
                           Margin="0,6,0,18"
                           Foreground="#FF475569"/>

                <Grid HorizontalAlignment="Center" Margin="0,0,0,18">
                    <Ellipse Width="180"
                             Height="180"
                             Fill="#FFEFF4FB"
                             Stroke="#FFD5DCEA"
                             StrokeThickness="1"/>
                    <Ellipse Width="170"
                             Height="170"
                             Margin="5">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding PreviewImage}" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <Border Background="#FFF8FAFC"
                        CornerRadius="18"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Nasvet"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#FF0F172A"/>
                        <TextBlock Text="Če imaš veliko sliko, povečaj krog in ga postavi na sredino obraza."
                                   Margin="0,8,0,0"
                                   Foreground="#FF475569"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Button Content="Ponastavi"
                        Margin="0,18,0,0"
                        Height="40"
                        Background="#FFE8EEF9"
                        Foreground="#FF1D4ED8"
                        BorderThickness="0"
                        Click="ResetSelection_Click"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1"
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Prekliči"
                    Width="110"
                    Height="42"
                    Margin="0,0,10,0"
                    Background="#FFE5E7EB"
                    Foreground="#FF0F172A"
                    BorderThickness="0"
                    Click="Cancel_Click"/>
            <Button Content="Shrani"
                    Width="110"
                    Height="42"
                    Background="#FF2563EB"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
